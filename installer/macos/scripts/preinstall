#!/bin/bash
# OpenAVC .pkg preinstall — runs as root before files are laid down.
#
# On an upgrade the daemon is running and holds the old binary + the HTTP
# port. Stop it first so the installer can replace /Applications/OpenAVC.app
# cleanly (the macOS analog of the Inno Setup PrepareToInstall service stop).
# Tolerate a fresh install where nothing is loaded yet.

launchctl bootout system/com.openavc.server 2>/dev/null || true

# Stop the menu-bar agent in the logged-in user's session too, so its binary
# isn't locked while the bundle is replaced.
CONSOLE_UID="$(stat -f %u /dev/console 2>/dev/null)"
if [ -n "${CONSOLE_UID:-}" ] && [ "$CONSOLE_UID" != "0" ]; then
    launchctl bootout "gui/$CONSOLE_UID/com.openavc.menubar" 2>/dev/null || true
fi

# Give launchd a moment to release the listening socket and file handles.
sleep 1

exit 0
