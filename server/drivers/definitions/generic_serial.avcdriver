# Generic Serial Device Driver
#
# Control any RS-232/RS-485 device with a text protocol — directly on a serial
# port or through an IP-to-serial bridge (e.g. a Global Caché iTach). Add the
# device, then define its commands and responses with the friendly tables on
# the device page (Commands & Responses). The line ending you choose there is
# appended to every command automatically, so commands don't need a literal \r.

id: generic_serial
name: Generic Serial Device
manufacturer: Generic
category: utility
version: 1.0.0
author: OpenAVC
description: >
  Control any RS-232/RS-485 device with a text protocol. Define commands and
  responses on the device page — no driver file needed.
transport: serial

# Enables the device-page Commands & Responses editor (commands / responses /
# state_variables are read from the device config and merged into this driver).
# The line ending lives in the device config (default_config.delimiter) so the
# editor's Line Ending control drives both command terminators and reply
# framing.
inline_protocol: true

default_config:
  port: ""
  baudrate: 9600
  parity: "N"
  bytesize: 8
  stopbits: 1
  delimiter: "\r"
  inter_command_delay: 0.1
  poll_interval: 0

config_schema:
  port:
    type: string
    required: true
    label: Serial Port
    description: "e.g., COM3 or /dev/ttyUSB0. Use SIM:name for simulation."
  baudrate:
    type: integer
    default: 9600
    label: Baud Rate
  parity:
    type: enum
    values: ["N", "E", "O"]
    default: "N"
    label: Parity
  bytesize:
    type: integer
    default: 8
    label: Data Bits
  stopbits:
    type: number
    default: 1
    label: Stop Bits
  inter_command_delay:
    type: number
    default: 0.1
    label: Inter-Command Delay (sec)

state_variables: {}
commands: {}
responses: []
polling: {}
